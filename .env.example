# =============================================================================
#  Sports Stream Platform — Environment variables template
#  Copy this file as ".env" and fill in the real values.
#  The actual ".env" file is listed in .gitignore and must NEVER be pushed to GitHub.
# =============================================================================


# ---------------------------------------------------------------------------
# Django — Core
# ---------------------------------------------------------------------------

# Generate a secure key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# True in local development / False in production
DJANGO_DEBUG=True

# In production: your real domain
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1


# ---------------------------------------------------------------------------
# Database (optional — SQLite by default)
# ---------------------------------------------------------------------------

# DATABASE_URL=postgres://user:password@host:5432/db_name


# ---------------------------------------------------------------------------
# API Cache
# ---------------------------------------------------------------------------

# Time-to-live for cached external API responses, in seconds (default: 3600)
API_CACHE_TTL=3600

# For Redis in production:
# CACHE_URL=redis://127.0.0.1:6379/1


# ---------------------------------------------------------------------------
# Sports APIs
# ---------------------------------------------------------------------------

# ⚠️ PRIVATE — Register at https://dashboard.api-football.com/
API_FOOTBALL_KEY=

# ✅ PUBLIC — "3" is the official public test key for TheSportsDB
THESPORTSDB_KEY=3

# Optional
API_TENNIS_KEY=
